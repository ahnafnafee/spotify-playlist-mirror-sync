{
  "name": "omni-sync-promo",
  "version": "1.0.0",
  "private": true,
  "description": "Remotion promo video for Omni Sync (Omni Playlist Sync)",
  "scripts": {
    "start": "remotion studio",
    "build:assets": "node scripts/build-assets.mjs",
    "render:mp4": "remotion render OmniSyncPromo out/omni-sync-demo.mp4 --codec=h264 --crf=18",
    "render:lite": "remotion render OmniSyncPromoLite out/omni-sync-lite.mp4 --codec=h264 --crf=16",
    "still": "remotion still OmniSyncPromo out/still.png",
    "upgrade": "remotion upgrade"
  },
  "dependencies": {
    "@remotion/cli": "4.0.489",
    "@remotion/google-fonts": "4.0.489",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "remotion": "4.0.489"
  },
  "devDependencies": {
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "typescript": "5.6.3"
  }
}
