# Required
APPLE_BEARER_TOKEN=
APPLE_USER_TOKEN=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Optional
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback
PLAYLISTS=                # comma-separated names; empty = every same-named pair
SYNC_INTERVAL=15m         # loop sleep (e.g. 900, 15m, 1h)
MAX_REMOVALS=25           # per-playlist removal cap per pass
MAX_ADDS=200              # per-playlist additions cap per pass (rest continue next pass)
DOWNLOAD_DIR=             # set to a folder to also keep local audio copies
#LOCAL_MIRROR_FORMAT=mp3  # flac/ogg/opus/m4a/wav; don't change after first run
#LOCAL_MIRROR_TIMEOUT=3600 # seconds per playlist per pass (first run may need more)
#LOCAL_MIRROR_ORDER=newest # m3u/date-added order: newest (top, like Spotify) | oldest
#LOCAL_MIRROR_TAG_BACKFILL=1 # backfill missing tags + cover art from Spotify (0 to disable)
#LOCAL_MIRROR_AUDIO_PROVIDERS=youtube-music youtube  # spotDL source fallback order
#LOCAL_MIRROR_VERBOSE=0    # 1 = echo all spotDL output
APPLE_STOREFRONT=us

# Optional: push real playlist covers to Jellyfin (m3u playlists can't carry a
# cover via files; the API is the only way). Create the key in Jellyfin ->
# Dashboard -> API Keys. From Docker, use http://host.docker.internal:8096.
#JELLYFIN_URL=http://localhost:8096
#JELLYFIN_API_KEY=
#JELLYFIN_USER_ID=       # optional; only if listing playlists needs a user
APPLE_CACHE_FILE=apple_resolve_cache.json
SONG_CACHE_FILE=song_cache.db
SPOTIFY_TRACKS_CACHE=spotify_tracks_cache.json  # playlist snapshots, keyed by Spotify snapshot_id
YTMUSIC_AUTH_FILE=ytmusic_browser.json   # created via: uv run ytmusicapi browser
YTMUSIC_CACHE_FILE=ytmusic_resolve_cache.json
SPOTIFY_TOKEN_CACHE=.cache
